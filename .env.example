# Anthropic API Key — get yours at https://console.anthropic.com/
ANTHROPIC_API_KEY=your-api-key-here

# OpenFDA API Key — optional, raises rate limit from 240 to 1000 req/min
# Request a free key at https://open.fda.gov/apis/authentication/
# Leave blank to use the anonymous tier (sufficient for 15 scans/day per IP)
OPENFDA_API_KEY=
